{{- /* RSS feed — drop-in Hugo default but with German labels */ -}}
{{- printf "<?xml version=\"1.0\" encoding=\"UTF-8\" ?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ if eq .Title site.Title }}{{ site.Title }}{{ else }}{{ .Title }} · {{ site.Title }}{{ end }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ site.Params.description }}</description>
    <language>{{ site.Language.Lang }}</language>
    <copyright>{{ site.Copyright }}</copyright>
    <lastBuildDate>{{ (index .Pages.ByLastmod.Reverse 0).Lastmod.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>
    <atom:link href="{{ .Permalink }}" rel="self" type="application/rss+xml" />
    {{- $pages := where .Pages "Type" "posts" -}}
    {{- $limit := site.Config.Services.RSS.Limit -}}
    {{- if ge $limit 0 }}{{ $pages = first $limit $pages }}{{ end -}}
    {{- range $pages }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      <author>{{ .Params.author | default site.Params.author }}</author>
      <guid>{{ .Permalink }}</guid>
      <description>
        {{- if site.Params.ShowFullTextinRSS -}}
          {{ .Content | html }}
        {{- else -}}
          {{ .Summary | html }}
        {{- end -}}
      </description>
    </item>
    {{- end }}
  </channel>
</rss>
